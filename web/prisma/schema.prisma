generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  
  isSuperAdmin Boolean  @default(false)

  memberships           TenantMembership[]
  devices               Device[]
  employeeAppCategories EmployeeAppCategory[]
}

model Package {
  id           String   @id @default(cuid())
  name         String
  maxAccounts  Int
  monthlyPrice Float
  hasCCTV      Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenants      Tenant[]
}

model SystemSettings {
  id         String @id @default("global")
  appName    String @default("NexusTrack")
  logoBase64 String?
}

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  subscriptionStatus String   @default("active")
  createdAt          DateTime @default(now())

  // Customer Management Fields
  customerId         String?  @unique
  primaryContactName String?
  primaryContactEmail String?
  primaryContactPhone String?
  renewalDate        DateTime?

  // Settings
  defaultScreenshotInterval Int      @default(300)
  idleTimeout               Int      @default(5)
  blurScreenshots           Boolean  @default(false)
  timezone                  String   @default("UTC")
  logoBase64                String?

  // Package Relation
  packageId          String?
  package            Package? @relation(fields: [packageId], references: [id])

  memberships           TenantMembership[]
  activityLogs          ActivityLog[]
  screenshots           Screenshot[]
  appCategories         AppCategory[]
  employeeAppCategories EmployeeAppCategory[]
}

enum ProductivityCategory {
  PRODUCTIVE
  UNPRODUCTIVE
  NEUTRAL
}

model AppCategory {
  id        String               @id @default(cuid())
  tenantId  String
  appName   String
  category  ProductivityCategory @default(NEUTRAL)
  
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, appName])
}

model EmployeeAppCategory {
  id        String               @id @default(cuid())
  userId    String
  tenantId  String
  appName   String
  category  ProductivityCategory @default(NEUTRAL)
  
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([userId, tenantId, appName])
}

model TenantMembership {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     Role   @default(EMPLOYEE)
  
  jobDescription String?
  screenshotInterval Int @default(60) // Frequency in seconds. 0 means disabled.
  
  
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Device {
  id           String   @id // Machine UUID
  userId       String
  osInfo       String
  lastPing     DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  activityLogs ActivityLog[]
  screenshots  Screenshot[]
}

model ActivityLog {
  id              String   @id @default(cuid())
  deviceId        String
  tenantId        String
  appName         String
  windowTitle     String
  durationSeconds Int
  isIdle          Boolean  @default(false)
  timestamp       DateTime @default(now())

  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id            String   @id @default(cuid())
  deviceId      String
  tenantId      String
  s3Url         String
  activityLevel Int
  timestamp     DateTime @default(now())

  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
