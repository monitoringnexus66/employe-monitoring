generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  
  isSuperAdmin Boolean  @default(false)

  memberships  TenantMembership[]
  devices      Device[]
}

model Package {
  id           String   @id @default(cuid())
  name         String
  maxAccounts  Int
  monthlyPrice Float
  createdAt    DateTime @default(now())

  tenants      Tenant[]
}

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  subscriptionStatus String   @default("active")
  createdAt          DateTime @default(now())

  // Customer Management Fields
  customerId         String?  @unique
  primaryContactName String?
  primaryContactEmail String?
  primaryContactPhone String?
  renewalDate        DateTime?

  // Settings
  defaultScreenshotInterval Int      @default(300)
  idleTimeout               Int      @default(5)
  blurScreenshots           Boolean  @default(false)
  timezone                  String   @default("UTC")

  // Package Relation
  packageId          String?
  package            Package? @relation(fields: [packageId], references: [id])

  memberships        TenantMembership[]
  activityLogs       ActivityLog[]
  screenshots        Screenshot[]
}

model TenantMembership {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     Role   @default(EMPLOYEE)
  
  screenshotInterval Int @default(60) // Frequency in seconds. 0 means disabled.
  
  
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Device {
  id           String   @id // Machine UUID
  userId       String
  osInfo       String
  lastPing     DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  activityLogs ActivityLog[]
  screenshots  Screenshot[]
}

model ActivityLog {
  id              String   @id @default(cuid())
  deviceId        String
  tenantId        String
  appName         String
  windowTitle     String
  durationSeconds Int
  isIdle          Boolean  @default(false)
  timestamp       DateTime @default(now())

  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id            String   @id @default(cuid())
  deviceId      String
  tenantId      String
  s3Url         String
  activityLevel Int
  timestamp     DateTime @default(now())

  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
